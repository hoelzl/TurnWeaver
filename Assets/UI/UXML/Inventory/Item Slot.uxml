<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:Button name="item-slot" style="width: 70px; height: 70px; margin: 5px; padding: 2px; background-color: rgb(40, 40, 40); border-width: 2px; border-color: rgb(60, 60, 60);">
        <ui:VisualElement name="item-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0);" />
        <ui:Label text="99" name="item-quantity" style="position: absolute; bottom: 0; right: 0; background-color: rgba(0, 0, 0, 0.7); color: rgb(255, 255, 255); padding: 2px; font-size: 10px; min-width: 16px; -unity-text-align: middle-center;" />
        <ui:Label text="75" name="price-label" style="position: absolute; top: 0; right: 0; background-color: rgba(255, 215, 0, 0.8); color: rgb(239, 239, 239); padding: 2px; font-size: 10px; min-width: 16px; -unity-text-align: middle-center; display: none;" />
    </ui:Button>
</ui:UXML>
