<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="interaction-menu-root" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; background-color: rgb(118, 118, 118); justify-content: flex-start;">
        <ui:VisualElement name="options-container" style="position: absolute; min-width: 200px; background-color: rgba(0, 0, 0, 0.8); border-radius: 5px; padding: 10px; right: 0; bottom: 64px; left: 0; top: 0; justify-content: flex-end;">
            <ui:ListView />
        </ui:VisualElement>
        <ui:Button name="cancel-button" text="Cancel" style="position: absolute; bottom: 10px; right: 20px; padding: 10px 20px; background-color: rgb(198, 40, 40); color: white; border-radius: 5px; left: 20px;" />
    </ui:VisualElement>
</ui:UXML>
